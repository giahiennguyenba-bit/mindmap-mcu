rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows anyone with your Firestore database reference to view, edit,
    // and delete all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At that time, all client
    // requests to your Firestore database will be denied.
    //
    // Make sure to write security rules for your app before that time, or else
    // all client requests to your Firestore database will be denied until you Update
    // your rules
    // Cho phép người dùng đọc/ghi dữ liệu cá nhân của chính họ
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /user_schedules/{scheduleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Cho phép ghi nhật ký cảm xúc nếu đã đăng nhập và userId khớp
    match /emotional_logs/{logId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Quy tắc dự phòng cho các collection khác (giữ lại test mode cho dev)
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 5, 28);
    }
  }
}